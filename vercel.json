{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "https://careertodo.com"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/fleet-management/:path*",
      "destination": "/:path*"
    }
  ]
}
